# Anthropic API Key (required for the Screening Response Generator tool)
# Get this from https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=your_api_key_here

# Resend API Key (required for the "Ask me anything" form to actually deliver email)
# Get this from https://resend.com/api-keys — free tier works, no domain
# verification needed since we send from Resend's shared onboarding@resend.dev sender.
RESEND_API_KEY=your_resend_api_key_here

# Password for the /admin feature-flag dashboard (pick any strong value).
# Must also be set in Vercel (Project → Settings → Environment Variables) for production.
ADMIN_PASSWORD=choose_a_strong_password
